{
  "expo": {
    "name": "WorkTrack",
    "slug": "worktrack-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#002C5F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.hyundai.worktrack",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Accès à la galerie pour joindre des rapports.",
        "NSCameraUsageDescription": "Accès à la caméra pour prendre des photos de documents.",
        "NSFileProviderDomainUsageDescription": "Accès aux fichiers pour joindre des rapports."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#002C5F"
      },
      "package": "com.hyundai.worktrack",
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ]
    ],
    "extra": {
      "apiUrl": "http://localhost:8000"
    }
  }
}
